# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

# Required
project_id = "your-gcp-project-id"

# Optional - defaults shown
region        = "us-central1"
service_name  = "genmedia-for-commerce"
memory        = "32Gi"
cpu           = "8"
timeout       = 3600
concurrency   = 7
min_instances = 2
max_instances = 10

# Authentication: "none", "iam", or "iap"
auth_mode = "iam"

# Optional: Grant access to entire domain
# iap_access_domain = "example.com"
