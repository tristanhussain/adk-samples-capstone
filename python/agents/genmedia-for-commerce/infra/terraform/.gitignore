# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for development
.terraformrc
terraform.rc

# Terraform lock file (optional - some teams commit this)
# .terraform.lock.hcl

# Terraform directory
.terraform/

# Sensitive variable files
terraform.tfvars
*.auto.tfvars

# Keep the example file
!terraform.tfvars.example
