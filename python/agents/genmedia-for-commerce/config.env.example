# GCP Configuration
PROJECT_ID=your-gcp-project-id

# Regions
GLOBAL_REGION=global
US_REGION=us-central1
EUROPE_REGION=europe-west4
DEFAULT_REGION=us-central1

# Cloud Run Deployment
SERVICE_NAME=genmedia-for-commerce
IMAGE_NAME=gcr.io/your-gcp-project-id/genmedia-for-commerce
MEMORY=32Gi
CPU=8
TIMEOUT=3600
CONCURRENCY=7
MAX_INSTANCES=10
MIN_INSTANCES=2

# Cloud Run authentication (IAM is always on, IAP is optional)
USE_IAP=false

# Catalog Search
EMBEDDING_MODEL=gemini-embedding-001

# Shoe Classifier
# Remote fine-tuned endpoint (None = use local embedding-based classifier)
SHOE_CLASSIFICATION_ENDPOINT=None
MULTIMODAL_EMBEDDING_MODEL=gemini-embedding-2-preview
