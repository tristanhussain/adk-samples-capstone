# Copy to `.env` in this directory and fill in values. See README for setup.

# Vertex AI / Gemini (used when GOOGLE_GENAI_USE_VERTEXAI=1)
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=1

# YouTube Data API v3 — you will be prompted to provide your API key during the agent session.
# To get a key, visit: https://developers.google.com/youtube/v3/getting-started
