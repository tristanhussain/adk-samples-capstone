# =============================================================================
# NexShift Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Google Cloud / Vertex AI (Option 1 - recommended for production)
# =============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Agent Engine deployment location (separate from GOOGLE_CLOUD_LOCATION)
AGENT_ENGINE_LOCATION=us-central1
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=TRUE
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE

# =============================================================================
# Gemini API Key (Option 2 - simpler for local development)
# =============================================================================
# GOOGLE_GENAI_API_KEY=your-gemini-api-key

# =============================================================================
# LLM Model Names (optional - defaults shown)
# =============================================================================
# NEXSHIFT_MODEL_COORDINATOR=gemini-3-flash-preview
# NEXSHIFT_MODEL_CONTEXT_GATHERER=gemini-3-flash-preview
# NEXSHIFT_MODEL_SOLVER=gemini-3-flash-preview
# NEXSHIFT_MODEL_COMPLIANCE=gemini-3.1-pro-preview
# NEXSHIFT_MODEL_EMPATHY=gemini-3.1-pro-preview
# NEXSHIFT_MODEL_PRESENTER=gemini-3-flash-preview
