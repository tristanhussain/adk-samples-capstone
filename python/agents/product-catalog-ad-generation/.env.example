# --- Runtime/General Configuration ---
# Used by the application logic (e.g., generative AI calls)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=1

# Backward-compatible aliases still read by some tool modules
GCP_PROJECT=${GOOGLE_CLOUD_PROJECT}
GCP_LOCATION=${GOOGLE_CLOUD_LOCATION}

COMPANY_NAME=ACME Corp
MODEL_NAME=gemini-2.5-flash
STORYLINE_MODEL_NAME=${MODEL_NAME}
EVALUATION_MODEL_NAME=${MODEL_NAME}
IMAGE_GEN_MODEL_NAME=gemini-3-pro-image-preview

# --- Deployment Configuration ---
# Used by the deployment scripts (01-*, 02-*)
REGION=us-central1
STAGING_BUCKET=${GOOGLE_CLOUD_PROJECT}-staging

# --- BigQuery Configuration (for 02-deploy-gcs-and-bq.sh) ---
# These are referenced within the script but can be overridden here if needed.
# BQ_DATASET="content_generation"
# BQ_TABLE="media_assets"
